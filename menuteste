local y = 90
local function AddToggle(name, default, callback)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0.9, 0, 0, 52)
    btn.Position = UDim2.new(0.05, 0, 0, y)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
    btn.Text = "   " .. name .. (default and " ✅" or " ❌")
    btn.TextColor3 = Color3.new(1,1,1)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    btn.TextScaled = true
    btn.Font = Enum.Font.GothamSemibold
    btn.Parent = Main
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)

    local state = default
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = "   " .. name .. (state and " ✅" or " ❌")
        callback(state)
    end)
    y = y + 62
end

AddToggle("ESP Box", true, function(v) Config.ESP_Box = v end)
AddToggle("Tracers", true, function(v) Config.Tracers = v end)
AddToggle("Skeleton", true, function(v) Config.Skeleton = v end)
AddToggle("Distance", true, function(v) Config.Distance = v end)
AddToggle("Names", true, function(v) Config.Names = v end)
AddToggle("Auto Interact", true, function(v) Config.AutoInteract = v end)
AddToggle("Noclip", false, function(v) Config.Noclip = v end)

-- ESP
RunService.RenderStepped:Connect(function()
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == LP or not plr.Character or not plr.Character:FindFirstChild("Head") then continue end

        local head = plr.Character.Head
        local screen, onScreen = Camera:WorldToViewportPoint(head.Position)
        local dist = LP.Character and LP.Character:FindFirstChild("Head") and (head.Position - LP.Character.Head.Position).Magnitude or 0

        if not ESPs[plr] then
            ESPs[plr] = {
                Box = Drawing.new("Square"),
                Tracer = Drawing.new("Line"),
                Name = Drawing.new("Text"),
                Distance = Drawing.new("Text")
            }
            local e = ESPs[plr]
            e.Box.Thickness = 1.5
            e.Box.Color = Color3.fromRGB(255, 100, 100)
            e.Tracer.Thickness = 1.4
            e.Tracer.Color = Color3.fromRGB(100, 200, 255)
            e.Name.Size = 14
            e.Name.Color = Color3.new(1,1,1)
            e.Name.Center = true
            e.Name.Outline = true
            e.Distance.Size = 13
            e.Distance.Color = Color3.new(1, 0.9, 0.6)
            e.Distance.Center = true
            e.Distance.Outline = true
        end

        local e = ESPs[plr]

        if onScreen then
            local size = 1700 / screen.Z
            local boxSize = Vector2.new(size*0.6, size*1.8)

            if Config.ESP_Box then
                e.Box.Size = boxSize
                e.Box.Position = Vector2.new(screen.X - boxSize.X/2, screen.Y - boxSize.Y/2)
                e.Box.Visible = true
            else
                e.Box.Visible = false
            end

            if Config.Tracers then
                e.Tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y - 40)
                e.Tracer.To = Vector2.new(screen.X, screen.Y)
                e.Tracer.Visible = true
            else
                e.Tracer.Visible = false
            end

            if Config.Names then
                e.Name.Text = plr.Name
                e.Name.Position = Vector2.new(screen.X, screen.Y - boxSize.Y/2 - 20)
                e.Name.Visible = true
            else
                e.Name.Visible = false
            end

            if Config.Distance then
                e.Distance.Text = math.floor(dist) .. "m"
                e.Distance.Position = Vector2.new(screen.X, screen.Y - boxSize.Y/2 - 5)
                e.Distance.Visible = true
            else
                e.Distance.Visible = false
            end
        else
            e.Box.Visible = false
            e.Tracer.Visible = false
            e.Name.Visible = false
            e.Distance.Visible = false
        end
    end
end)

-- Auto Interact + Noclip
RunService.Heartbeat:Connect(function()
    if Config.AutoInteract and LP.Character then
        for _, prompt in ipairs(workspace:GetDescendants()) do
            if prompt:IsA("ProximityPrompt") and prompt.Enabled then
                local dist = (LP.Character.HumanoidRootPart.Position - prompt.Parent.Position).Magnitude
                if dist < 12 then
                    prompt:InputHoldBegin()
                    task.wait(prompt.HoldDuration + 0.1)
                    prompt:InputHoldEnd()
                end
            end
        end
    end
end)

RunService.Stepped:Connect(function()
    if Config.Noclip and LP.Character then
        for _, part in pairs(LP.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
end)

