-- Partículas fofas
local function CreateParticle()
    local p = Instance.new("Frame")
    p.Size = UDim2.new(0, 7, 0, 7)
    p.BackgroundColor3 = Color3.fromRGB(255, math.random(160,255), 220)
    p.BorderSizePixel = 0
    p.Parent = Main
    Instance.new("UICorner", p).CornerRadius = UDim.new(1,0)
    
    local x = math.random(30, Main.AbsoluteSize.X - 30)
    p.Position = UDim2.new(0, x, 1, 0)
    
    TweenService:Create(p, TweenInfo.new(math.random(7,13), Enum.EasingStyle.Linear), {
        Position = UDim2.new(0, math.random(30, Main.AbsoluteSize.X - 30), -0.1, 0),
        BackgroundTransparency = 1
    }):Play()
    
    task.delay(14, function() p:Destroy() end)
end

task.spawn(function()
    while true do
        for i = 1, 3 do CreateParticle() end
        task.wait(0.35)
    end
end)

